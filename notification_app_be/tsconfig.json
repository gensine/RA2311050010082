{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020", "DOM"],
    "outDir": "./dist",
    "declaration": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "logging-middleware": ["../logging_middleware/src/index"]
    }
  },
  "include": ["src/**/*", "../logging_middleware/src/**/*"],
  "exclude": ["node_modules", "dist"]
}
